datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique
  passwordHash String
  xp           Int         @default(0)
  level        Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  profileImage String?
  coverImage   String?
  
  videos       Video[]
  passwords    Password[]
  torrents     Torrent[]
  files        File[]
  folders      Folder[]
  wallpapers   Wallpaper[]
  software     Software[]
  notes        Note[]
  goals        Goal[]
  devComponents DevComponent[]
  receipts      Receipt[]
  bills         Bill[]
  bankAccounts  BankAccount[]
  authenticators Authenticator[]
}

model Video {
  id           String   @id @default(uuid())
  title        String
  url          String
  thumbnailUrl String?
  duration     Int?     // duration in seconds
  progress     Int      @default(0) // progress in seconds
  isFavorite   Boolean  @default(false)
  category     String?
  tags         String?  // comma-separated tags
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Password {
  id           String   @id @default(uuid())
  title        String
  username     String?
  email        String?
  password     String   // AES-256 encrypted string
  url          String?
  imageUrl     String?  // App Logo/Banner URL
  notes        String?
  category     String?
  tags         String?  // comma-separated tags
  isFavorite   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Torrent {
  id            String   @id @default(uuid())
  title         String
  magnet        String   @unique
  status        String   @default("queued") // queued, downloading, seeding, paused, completed
  progress      Float    @default(0.0)      // percentage 0 to 100
  downloadSpeed Float    @default(0.0)      // in MB/s
  uploadSpeed   Float    @default(0.0)      // in MB/s
  size          String   // human-readable size e.g., "1.4 GB"
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Folder {
  id             String   @id @default(uuid())
  name           String
  parentFolderId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  parentFolder   Folder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: Cascade)
  childFolders   Folder[] @relation("FolderHierarchy")
  files          File[]
}

model File {
  id         String   @id @default(uuid())
  name       String
  path       String   // local file/upload URL
  size       Int      // in bytes
  mimeType   String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  folderId   String?
  folder     Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallpaper {
  id         String   @id @default(uuid())
  title      String
  url        String
  width      Int?
  height     Int?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Software {
  id          String   @id @default(uuid())
  name        String
  version     String
  description String?
  downloadUrl String?
  platform    String   // Windows, macOS, Linux, Web
  iconUrl     String?
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id         String   @id @default(uuid())
  title      String
  content    String   // Markdown body
  category   String?
  tags       String?  // comma-separated tags
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id           String   @id @default(uuid())
  title        String
  targetValue  Float?
  currentValue Float?
  isCompleted  Boolean  @default(false)
  deadline     DateTime?
  xpReward     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DevComponent {
  id          String   @id @default(uuid())
  title       String
  description String?
  htmlCode    String?
  cssCode     String?
  jsCode      String?
  category    String?
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Receipt {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String?  // URL ou caminho do comprovante
  amount      Float?   // valor
  paymentDate DateTime? // data do pagamento
  category    String?  // categoria do comprovante
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bill {
  id           String    @id @default(uuid())
  title        String
  description  String?
  amount       Float
  dueDate      DateTime  // data de vencimento
  type         String    // "pagar", "receber", "agendar"
  status       String    @default("pendente") // "pendente", "pago", "recebido", "agendado"
  paymentDate  DateTime? // data de pagamento real
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            String   @id @default(uuid())
  provider      String   // e.g. "Mercado Pago", "Santander", "Nubank"
  balance       Float    @default(0.0)
  trend         String   @default("+0.0% este mês")
  lastSync      DateTime @default(now())
  accountNumber String?
  apiKey        String?
  apiSecret     String?
  syncType      String   @default("manual") // manual, openfinance, ofx
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reward {
  id          String    @id @default(uuid())
  title       String    // e.g. "Pix de R$ 10", "Pix de R$ 50"
  costXp      Int       // custo em XP
  amount      Float     // valor em R$
  status      String    @default("disponivel") // disponivel, resgatado
  claimedBy   String?   // username de quem resgatou
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Authenticator {
  id                   String   @id @default(uuid())
  credentialID         String   @unique
  credentialPublicKey  String   // Armazenado como base64
  counter              BigInt   @default(0)
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?  // lista de transportes separados por virgula
  createdAt            DateTime @default(now())
  
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
